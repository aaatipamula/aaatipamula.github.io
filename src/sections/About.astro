---
import type { DisplayItem } from "@components/Websites.astro";

import Section from "@layouts/Section.astro";
import Websites from "@components/Websites.astro";

import blogPng from "@img/2026-01-17-133100_hyprshot.png";
import gardenPng from "@img/2026-01-17-133131_hyprshot.png";
import terminalPng from "@img/2026-01-17-133143_hyprshot.png";
import sandboxPng from "@img/2026-01-17-133204_hyprshot.png";
import previewPng from "@img/2026-01-17-133223_hyprshot.png";

const WEBSITES: DisplayItem[] = [ 
  {
    image: blogPng,
    caption: "blog.aniketh.dev",
    link: "https://blog.aniketh.dev",
    note: "My personal blog!",
  },
  {
    image: gardenPng,
    caption: "garden.aniketh.dev",
    link: "https://garden.aniketh.dev",
    note: "Some notes 'n reference stuff",
  },
  {
    image: terminalPng,
    caption: "terminal.aniketh.dev",
    link: "https://terminal.aniketh.dev",
    note: "A terminal-like experience for browsing GitHub",
  },
  {
    image: sandboxPng,
    caption: "sandbox.aniketh.dev",
    link: "https://sandbox.aniketh.dev",
    note: "A collection of random single page applications",
  },
  {
    image: previewPng,
    caption: "preview.aniketh.dev",
    link: "https://preview.aniketh.dev",
    note: "An experimental website to mess around with stuff",
  },
]
---

<Section name="about">
  <h1>About Me</h1>
  <span class="tagline">Hey, I'm Aniketh, a developer, student, and hobbyist.</span>
  <p>
I'm currently pursuing a <em>B.S. in Computer Science</em> with a Minor in Math at <a href="https://eecs.ku.edu"> University of Kansas</a>.
  </p>

  <h2 class="text-center">Other Websites</h2>
  <Websites items={WEBSITES} />

</Section>

